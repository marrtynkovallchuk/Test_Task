SELECT
    ROUND(
        COUNT(read_ts) * 100.0
        / COUNT(delivery_ts),
        2
    ) AS open_rate,

    ROUND(
        COUNT(click_ts) * 100.0
        / COUNT(read_ts),
        2
    ) AS click_to_open_rate,

    ROUND(
        COUNTIF(total_credits > 0) * 100.0
        / COUNT(click_ts),
        2
    ) AS click_to_payment_rate
FROM `testtask-497419.Test_Task.Test_Task`;
